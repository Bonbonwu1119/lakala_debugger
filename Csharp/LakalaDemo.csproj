<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>LakalaDemo</RootNamespace>
    <AssemblyName>LakalaDemo</AssemblyName>
    <!-- .NET 8 (LTS). 也可改成 net6.0 / net7.0 / net9.0, 同代码兼容 -->
  </PropertyGroup>

  <ItemGroup>
    <!-- SM4/ECB/PKCS5Padding 用 BouncyCastle. 标准 .NET 没有原生 SM4 实现. -->
    <PackageReference Include="BouncyCastle.Cryptography" Version="2.4.0" />
  </ItemGroup>

</Project>
