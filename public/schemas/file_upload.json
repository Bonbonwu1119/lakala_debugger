{
  "id": "file_upload",
  "category": "开户进件类接口",
  "name": "文件上传",
  "description": "进件附件上传接口。请求/响应都是明文 JSON, 不加密。file_base64 用 data:image/...;base64,... 的 Data URL 格式。返回的 url 拿到后用作 attchments[].id 提交进件。",
  "method": "POST",
  "url_test": "https://test.wsmsd.cn/sit/api/v3/tkbs/customer/file/upload",
  "url_prod": "https://s2.lakala.com/api/v3/tkbs/customer/file/upload",
  "doc_url": "",
  "fields": [
    { "path": "ver",                  "type": "string", "required": true,  "desc": "版本号 1.0.0" },
    { "path": "timestamp",            "type": "number", "required": true,  "desc": "秒级时间戳" },
    { "path": "req_data",             "type": "object", "required": true,  "desc": "请求数据" },
    { "path": "req_data.file_base64", "type": "string", "required": true,  "desc": "图片 Data URL: data:image/png;base64,xxx 或 data:image/jpeg;base64,xxx" },
    { "path": "req_data.img_type",    "type": "string", "required": true,  "desc": "图片类型: SHOP_INSIDE_IMG / SHOP_OUTSIDE_IMG / CHECKSTAND_IMG / LICENSE_IMG / ID_CARD_FRONT / ID_CARD_BACK / BANK_CARD ..." },
    { "path": "req_data.sourcechnl",  "type": "string", "required": false, "desc": "来源渠道, 默认 0" },
    { "path": "req_data.is_ocr",      "type": "string", "required": false, "desc": "是否 OCR 识别, true / false" }
  ],
  "example": {
    "ver": "1.0.0",
    "timestamp": "{{timestamp}}",
    "req_data": {
      "file_base64": "data:image/png;base64,REPLACE_WITH_BASE64_DATA_URL",
      "img_type": "SHOP_INSIDE_IMG",
      "sourcechnl": "0",
      "is_ocr": "false"
    }
  },
  "response_example": {
    "code": "000000",
    "msg": "SUCCESS",
    "resp_data": {
      "batch_no": null,
      "status": "00",
      "url": "merchant/imgages/20251123233957705762SHOP_INSIDE_IMG.jpeg",
      "show_url": "https://lkl-zf-cdmp.oss-cn-shanghai.aliyuncs.com/pd/huituoke/merchant/imgages/...?Expires=...&Signature=..."
    }
  }
}
