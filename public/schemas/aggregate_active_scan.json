{
  "id": "aggregate_active_scan",
  "category": "支付交易类接口",
  "name": "聚合主扫",
  "description": "聚合主扫接口, 按 trans_type 区分三种主流场景:\n\n  • trans_type=41 (NATIVE 扫码): account_type 只支持 ALIPAY 或 UQRCODEPAY (云闪付). 响应 resp_data.code 是一段 URL, 客户端把 URL 转成二维码让用户用对应 App 扫码完成支付.\n\n  • trans_type=51 (JSAPI): 支持微信公众号 / 支付宝生活号 / 支付宝 H5 应用 / 支付宝小程序 / 银联 JS. 传相应的 acc_busi_fields 域后, 可以直接在微信/支付宝/云闪付 App 内完成支付 (JSAPI 跳起). 微信场景比支付宝常用, 云闪付少见.\n\n  • trans_type=71 (微信小程序, 最常用): 仅支持微信小程序内支付. 传 acc_busi_fields 后在小程序内拉起.\n\n请求/响应均明文 JSON, 不加密, 仅做 SHA256withRSA 加签/验签.",
  "method": "POST",
  "url_test": "https://test.wsmsd.cn/sit/api/v3/labs/trans/preorder",
  "url_prod": "https://s2.lakala.com/api/v3/labs/trans/preorder",
  "doc_url": "https://o.lakala.com/#/home/document/detail",
  "fields": [
    { "path": "version",                              "required": true,  "desc": "接口版本号, 固定 3.0" },
    { "path": "req_time",                             "required": true,  "desc": "请求时间 yyyyMMddHHmmss (工具自动填)" },
    { "path": "out_org_code",                         "required": false, "desc": "组织代码 (机构方代发场景)" },
    { "path": "req_data.merchant_no",                 "required": true,  "desc": "商户号 (拉卡拉分配)" },
    { "path": "req_data.term_no",                     "required": true,  "desc": "终端号 (拉卡拉分配的业务终端)" },
    { "path": "req_data.out_trade_no",                "required": true,  "desc": "商户交易流水号, 唯一" },
    { "path": "req_data.account_type",                "required": true,  "desc": "钱包类型: WECHAT / ALIPAY / UQRCODEPAY(云闪付) / DCPAY(数币) / BESTPAY(翼支付) / SUNING(苏宁). 受 trans_type 限制: trans_type=41 仅支持 ALIPAY 和 UQRCODEPAY; trans_type=71 仅支持 WECHAT" },
    { "path": "req_data.trans_type",                  "required": true,  "desc": "接入方式 — 三种主流: 41=NATIVE 扫码 (用户扫商户码, 响应 code 是 URL, 客户端转二维码) / 51=JSAPI (微信公众号/支付宝生活号/H5/支付宝小程序/银联JS, 在 App 内直接支付) / 71=微信小程序 (最常用). 其他: 61=APP / 81=H5" },
    { "path": "req_data.total_amount",                "required": true,  "desc": "金额, 单位: 分 (字符串)" },
    { "path": "req_data.location_info",               "required": true,  "desc": "地址位置信息 (风控要求)" },
    { "path": "req_data.location_info.request_ip",    "required": true,  "desc": "请求方 IP, 必填" },
    { "path": "req_data.location_info.base_station",  "required": false, "desc": "基站信息" },
    { "path": "req_data.location_info.location",      "required": false, "desc": "纬度/经度, 格式 +23.137208/+113.381982" },
    { "path": "req_data.acc_busi_fields",             "required": false, "desc": "账户端业务信息域 — trans_type=51/71 必填, 不同账户类型字段不同. 微信小程序 (71): sub_appid + sub_openid; 微信公众号 (51): sub_appid + sub_openid; 支付宝 H5/小程序 (51): buyer_id 或 buyer_logon_id. 详见拉卡拉文档" },
    { "path": "req_data.acc_busi_fields.sub_appid",   "required": false, "desc": "[WECHAT, trans_type=51/71] 商户小程序/公众号的 AppID" },
    { "path": "req_data.acc_busi_fields.sub_openid",  "required": false, "desc": "[WECHAT, trans_type=51/71] 用户在该 sub_appid 下的 openid" },
    { "path": "req_data.acc_busi_fields.buyer_id",    "required": false, "desc": "[ALIPAY, trans_type=51] 支付宝买家 user_id (2088 开头)" },
    { "path": "req_data.busi_mode",                   "required": false, "desc": "业务模式: ACQ-收单 (默认)" },
    { "path": "req_data.subject",                     "required": false, "desc": "订单标题 (最多 42 字符)" },
    { "path": "req_data.pay_order_no",                "required": false, "desc": "拉卡拉支付业务订单号" },
    { "path": "req_data.notify_url",                  "required": false, "desc": "商户通知地址 (支付成功后异步回调)" },
    { "path": "req_data.settle_type",                 "required": false, "desc": "结算类型: 0 或空=常规结算" },
    { "path": "req_data.remark",                      "required": false, "desc": "备注" },
    { "path": "req_data.promo_info",                  "required": false, "desc": "拉卡拉优惠相关信息" },
    { "path": "req_data.out_order_no",                "required": false, "desc": "外部订单号" },
    { "path": "req_data.pnr_ins_id_cd",               "required": false, "desc": "银联服务商机构标识码" },
    { "path": "req_data.qb_amount",                   "required": false, "desc": "区补优惠金额 (分)" },
    { "path": "req_data.gb_amount",                   "required": false, "desc": "国补优惠金额 (分)" }
  ],
  "example": {
    "req_time": "{{req_time}}",
    "version": "3.0",
    "req_data": {
      "merchant_no": "82229007392000A",
      "term_no": "D9296400",
      "out_trade_no": "{{out_trade_no}}",
      "account_type": "WECHAT",
      "trans_type": "71",
      "total_amount": "1",
      "notify_url": "http://example.com/notify",
      "location_info": {
        "request_ip": "192.168.1.1",
        "location": "+23.137208/+113.381982"
      },
      "subject": "测试订单",
      "acc_busi_fields": {
        "sub_appid": "wx1234567890abcdef",
        "sub_openid": "ozUVw5_PLACEHOLDER_openid"
      }
    }
  },
  "response_example": {
    "code": "BBS00000",
    "msg": "成功",
    "resp_time": "20240626155843",
    "resp_data": {
      "merchant_no": "82229007392000A",
      "out_trade_no": "TEST123456789",
      "trade_no": "2024062666210315450047",
      "log_no": "66210315450047",
      "acc_resp_fields": {
        "_comment_71": "trans_type=71 (微信小程序) 返回这些字段, 用于客户端拉起小程序支付",
        "appid": "wx1234567890abcdef",
        "timestamp": "1719381523",
        "noncestr": "abcdef...",
        "package": "prepay_id=wx2624155843...",
        "signtype": "RSA",
        "paysign": "...",
        "_comment_41": "trans_type=41 (扫码) 时 code 是 URL, 转二维码让用户扫",
        "code": "https://qr.alipay.com/...",
        "code_image": ""
      }
    }
  }
}
