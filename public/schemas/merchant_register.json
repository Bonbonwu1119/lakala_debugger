{
  "id": "merchant_register",
  "category": "开户进件类接口",
  "name": "新增进件",
  "description": "拓客 SAAS 新增进件接口。整体报文 SM4 加密：HTTP 请求 body 是一段 base64 密文（不是 JSON），响应 body 也是 base64 密文；签名对密文做。req_data 字段非常多，下面字段说明只列了主要项，按实际文档增删。",
  "method": "POST",
  "url_test": "https://test.wsmsd.cn/sit/api/v3/tkbs/merchant_encry",
  "url_prod": "https://s2.lakala.com/api/v3/tkbs/merchant_encry",
  "doc_url": "",
  "encrypt": {
    "request":  { "mode": "whole" },
    "response": { "mode": "whole" }
  },
  "fields": [
    { "path": "ver",                            "type": "string", "required": true,  "desc": "接口版本号，1.0" },
    { "path": "timestamp",                      "type": "string", "required": true,  "desc": "毫秒级时间戳字符串 (工具自动填)" },
    { "path": "req_id",                         "type": "string", "required": true,  "desc": "请求流水号 (工具自动填)" },
    { "path": "req_data",                       "type": "object", "required": true,  "desc": "进件业务数据 — 整个 body 会一起加密" },
    { "path": "req_data.org_code",              "type": "string", "required": true,  "desc": "组织代码 (拉卡拉分配)" },
    { "path": "req_data.user_no",               "type": "string", "required": true,  "desc": "代理商业务员编号" },
    { "path": "req_data.source",                "type": "string", "required": true,  "desc": "进件来源, 例: H5" },
    { "path": "req_data.mer_type",              "type": "string", "required": true,  "desc": "商户类型: TP_PERSONAL / TP_ENTERPRISE 等" },
    { "path": "req_data.mer_name",              "type": "string", "required": true,  "desc": "商户名称" },
    { "path": "req_data.mer_reg_name",          "type": "string", "required": true,  "desc": "商户注册名称" },
    { "path": "req_data.mer_addr",              "type": "string", "required": true,  "desc": "商户经营地址" },
    { "path": "req_data.busi_code",             "type": "string", "required": true,  "desc": "业务类型码: WECHAT_PAY 等" },
    { "path": "req_data.contact_name",          "type": "string", "required": true,  "desc": "联系人姓名" },
    { "path": "req_data.contact_mobile",        "type": "string", "required": true,  "desc": "联系人手机号" },
    { "path": "req_data.email",                 "type": "string", "required": false, "desc": "联系人邮箱" },

    { "path": "req_data.lar_id_type",           "type": "string", "required": true,  "desc": "法人证件类型, 01=身份证" },
    { "path": "req_data.lar_name",              "type": "string", "required": true,  "desc": "法人姓名" },
    { "path": "req_data.lar_id_card",           "type": "string", "required": true,  "desc": "法人证件号" },
    { "path": "req_data.lar_id_card_start",     "type": "string", "required": true,  "desc": "法人证件起始日 yyyy-MM-dd" },
    { "path": "req_data.lar_id_card_end",       "type": "string", "required": true,  "desc": "法人证件到期日 yyyy-MM-dd, 长期写 9999-12-31" },

    { "path": "req_data.license_no",            "type": "string", "required": false, "desc": "营业执照号 (个体/企业必填)" },
    { "path": "req_data.license_name",          "type": "string", "required": false, "desc": "营业执照名称" },
    { "path": "req_data.license_dt_start",      "type": "string", "required": false, "desc": "营业执照起始日" },
    { "path": "req_data.license_dt_end",        "type": "string", "required": false, "desc": "营业执照到期日, 长期 9999-12-31" },

    { "path": "req_data.account_type",          "type": "string", "required": true,  "desc": "结算账户类型, 58=对私借记卡" },
    { "path": "req_data.account_name",          "type": "string", "required": true,  "desc": "结算户名" },
    { "path": "req_data.account_no",            "type": "string", "required": true,  "desc": "结算账号" },
    { "path": "req_data.account_id_card",       "type": "string", "required": true,  "desc": "结算人证件号" },
    { "path": "req_data.account_id_dt_start",   "type": "string", "required": true,  "desc": "结算人证件起始日" },
    { "path": "req_data.account_id_dt_end",     "type": "string", "required": true,  "desc": "结算人证件到期日" },
    { "path": "req_data.openning_bank_code",    "type": "string", "required": true,  "desc": "开户行联行号" },
    { "path": "req_data.openning_bank_name",    "type": "string", "required": true,  "desc": "开户行名称" },
    { "path": "req_data.clearing_bank_code",    "type": "string", "required": true,  "desc": "清算行号" },
    { "path": "req_data.settle_type",           "type": "string", "required": true,  "desc": "结算方式, D1 = T+1" },

    { "path": "req_data.province_code",         "type": "string", "required": true,  "desc": "省码" },
    { "path": "req_data.city_code",             "type": "string", "required": true,  "desc": "市码" },
    { "path": "req_data.county_code",           "type": "string", "required": true,  "desc": "区/县码" },
    { "path": "req_data.settle_province_code",  "type": "string", "required": true,  "desc": "结算省码" },
    { "path": "req_data.settle_province_name",  "type": "string", "required": true,  "desc": "结算省名" },
    { "path": "req_data.settle_city_code",      "type": "string", "required": true,  "desc": "结算市码" },
    { "path": "req_data.settle_city_name",      "type": "string", "required": true,  "desc": "结算市名" },
    { "path": "req_data.latitude",              "type": "string", "required": false, "desc": "纬度" },
    { "path": "req_data.longtude",              "type": "string", "required": false, "desc": "经度" },

    { "path": "req_data.business_content",      "type": "string", "required": true,  "desc": "经营内容" },
    { "path": "req_data.attchments",            "type": "array",  "required": true,  "desc": "附件清单, 元素 {id, type}, type 例: CHECKSTAND_IMG / SHOP_OUTSIDE_IMG / SHOP_INSIDE_IMG / LICENSE_IMG ..." },

    { "path": "req_data.biz_content",           "type": "object", "required": true,  "desc": "业务参数" },
    { "path": "req_data.biz_content.activity_id","type": "string","required": true,  "desc": "活动 ID" },
    { "path": "req_data.biz_content.mcc",       "type": "string", "required": true,  "desc": "MCC 行业代码" },
    { "path": "req_data.biz_content.term_num",  "type": "string", "required": true,  "desc": "终端数量" },
    { "path": "req_data.biz_content.fees",      "type": "array",  "required": true,  "desc": "费率清单, 元素 {fee_code, fee_value, [top_fee]}" }
  ],
  "example": {
