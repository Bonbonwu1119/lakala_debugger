{
  "id": "trans_preorder",
  "category": "支付交易类接口",
  "name": "交易预下单",
  "description": "商户下单后获取支付参数，调起支付。支持支付宝、微信、云闪付等支付方式。",
  "method": "POST",
  "url_test": "https://test.wsmsd.cn/sit/api/v3/labs/trans/preorder",
  "url_prod": "https://s2.lakala.com/api/v3/labs/trans/preorder",
  "doc_url": "https://o.lakala.com",
  "fields": [
    { "path": "version", "type": "string", "required": true, "desc": "接口版本号，固定 3.0" },
    { "path": "req_time", "type": "string", "required": true, "desc": "请求时间，格式 yyyyMMddHHmmss (发送时工具自动填充)" },
    { "path": "req_data.merchant_no", "type": "string", "required": true, "desc": "拉卡拉分配的商户号" },
    { "path": "req_data.term_no", "type": "string", "required": true, "desc": "拉卡拉分配的终端号" },
    { "path": "req_data.out_trade_no", "type": "string", "required": true, "desc": "商户系统内的订单号，需保证唯一" },
    { "path": "req_data.account_type", "type": "string", "required": true, "desc": "账户类型：ALIPAY=支付宝, WECHAT=微信, UNIONPAY=云闪付" },
    { "path": "req_data.trans_type", "type": "string", "required": true, "desc": "交易类型：41=主扫(用户扫商户码), 47=被扫(商户扫用户码)" },
    { "path": "req_data.total_amount", "type": "number", "required": true, "desc": "交易金额，单位：分" },
    { "path": "req_data.notify_url", "type": "string", "required": false, "desc": "异步通知地址，交易结果会 POST 到这里" },
    { "path": "req_data.subject", "type": "string", "required": false, "desc": "商品标题/订单标题" },
    { "path": "req_data.location_info.request_ip", "type": "string", "required": false, "desc": "用户终端 IP" },
    { "path": "req_data.location_info.location", "type": "string", "required": false, "desc": "用户终端地理位置，格式 +纬度/+经度" }
  ],
  "example": {
    "req_time": "{{req_time}}",
    "version": "3.0",
    "req_data": {
      "merchant_no": "82229007392000A",
      "term_no": "D9296400",
      "out_trade_no": "{{out_trade_no}}",
      "account_type": "ALIPAY",
      "trans_type": "41",
      "total_amount": 1,
      "notify_url": "http://example.com/notify",
      "location_info": {
        "request_ip": "192.168.1.1",
        "location": "+23.137208/+113.381982"
      },
      "subject": "测试订单"
    }
  },
  "response_example": {
    "code": "BBS00000",
    "msg": "成功",
    "resp_time": "20240626155843",
    "resp_data": {
      "merchant_no": "82229007392000A",
      "out_trade_no": "TEST123456789",
      "trade_no": "2024062666210315450047",
      "log_no": "66210315450047",
      "acc_resp_fields": {
        "code": "https://qr.alipay.com/...",
        "code_image": ""
      }
    }
  }
}
